# LuckyD Code Configuration
# Uncomment ONE provider section. The agent auto-detects which API key is set.

# ── DeepSeek (default) ──
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI ──
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ──
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Google Gemini ──
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_MODEL=gemini-2.0-flash
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Ollama (local) ──
# OLLAMA_MODEL=codellama
# OLLAMA_HOST=http://localhost:11434

# ── Z.ai (GLM) ──
# ZAI_API_KEY=sk-your-zai-key
# ZAI_MODEL=glm-4.5
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# ── OpenRouter (200+ models) ──
# OPENROUTER_API_KEY=sk-or-your-openrouter-key
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── MCP (Model Context Protocol) ──
# See mcp_config.example.json for setup
# CODING_AGENT_MCP_CONFIG=C:/path/to/mcp_config.json

# ── Global Settings ──
# CODING_AGENT_PROVIDER=deepseek   # Explicit: deepseek, openai, anthropic, google, ollama
# CODING_AGENT_MODEL=auto          # Model override
# CODING_AGENT_THINKING=false      # Enable reasoning/thinking mode
# CODING_AGENT_TEMP=0.0
# CODING_AGENT_MAX_TOKENS=8192
# CODING_AGENT_MAX_TURNS=30
# CODING_AGENT_TIMEOUT=120
# CODING_AGENT_LOG_LEVEL=INFO      # DEBUG, INFO, WARNING, ERROR
# CODING_AGENT_LOG_FORMAT=readable # readable or json
